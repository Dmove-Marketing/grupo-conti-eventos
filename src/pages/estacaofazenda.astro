---
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/bio.css';

const LOGO  = 'https://media.dmove.com.br/clients/grupo-conti/photos/Logo-Conti-Preferencial-Claro.webp';
const DMOVE = 'https://media.dmove.com.br/clients/grupo-conti/photos/Logotipo-dmove.webp';
const HERO  = 'https://media.dmove.com.br/clients/grupo-conti/photos/carrossel-_Jarinu01_resultado.webp';
const MAPS  = 'https://maps.google.com/?q=Estr.+Mun.+Natal+Lorencini+-+Pitangal,+Jarinu+-+SP,+13240-000';
const SITE  = 'https://espaco.contieventos.com.br/';
const INSTA = 'https://www.instagram.com/grupocontieventos/';

const whatsAppStep1Fields = [
  {
    name: 'Tipo de evento',
    type: 'select' as const,
    label: 'Tipo de evento',
    required: true,
    options: [
      { value: '', label: 'Tipo de evento', disabled: true, selected: true },
      { value: 'Casamento', label: 'Casamento' },
      { value: 'Bodas', label: 'Bodas' },
      { value: 'Aniversário', label: 'Aniversário' },
      { value: 'Aniversário debutante', label: 'Aniversário debutante' },
      { value: 'Confraternização social', label: 'Confraternização social' },
      { value: 'Formatura', label: 'Formatura' },
      { value: 'Corporativo', label: 'Corporativo' },
      { value: 'Outros', label: 'Outros' },
    ],
  },
  {
    name: 'data',
    type: 'date' as const,
    label: 'Data do evento',
    required: true,
  },
  {
    name: 'Convidados',
    type: 'number' as const,
    label: 'Nº de convidados',
    placeholder: 'Ex: 150',
    required: true,
  },
];
---

<Base
  title="Estação Fazenda | Grupo Conti Eventos — Jarinu, SP"
  description="Arquitetura rústica, jardins exuberantes, capela e salão com pé-direito alto em Jarinu. Até 200 convidados. Infraestrutura completa para casamentos no campo."
  ogImage="/images/og-default.jpg"
  canonical={`${SITE}estacaofazenda/`}
  noIndex={true}
  whatsAppStep1Fields={whatsAppStep1Fields}
  whatsAppMessage={"Olá! Tenho interesse na Estação Fazenda.\nPode me ajudar com informações e orçamento?"}
>

  <!-- HERO -->
  <section class="bio-hero">
    <img src={HERO} alt="Estação Fazenda — Jarinu, SP" class="bio-hero-img" style="object-position: center center;" />
    <div class="bio-hero-overlay"></div>
    <div class="bio-hero-content bio-hero-content--center">
      <img src={LOGO} alt="Grupo Conti Eventos" class="bio-logo" width="300" height="100" />
      <span class="bio-eyebrow">Grupo Conti Eventos · Jarinu, SP</span>
      <h1 class="bio-headline">Estação Fazenda</h1>
      <p class="bio-subline">Natureza, elegância e estrutura para o seu grande dia</p>
    </div>
  </section>

  <!-- LINKS RÁPIDOS -->
  <section class="bio-links-section" style="padding-top:28px; padding-bottom:16px;">
    <div class="bio-links">
      <a href="#solicitar" class="bio-link-btn bio-link-btn--gold">Solicitar orçamento</a>
      <a href={MAPS} target="_blank" rel="noopener" class="bio-link-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Estr. Mun. Natal Lorencini — Pitangal · Jarinu, SP
      </a>
      <a href="/bio" class="bio-link-btn">Ver todos os espaços Grupo Conti</a>
    </div>
    <div class="bio-social">
      <a href={INSTA} target="_blank" rel="noopener" class="bio-social-btn" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <a href={SITE} target="_blank" rel="noopener" class="bio-social-btn" aria-label="Site">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- FORMULÁRIO -->
  <section class="bio-form-section" id="solicitar">
    <span class="bio-section-label">Orçamento</span>
    <h2 class="bio-section-title">Solicite um orçamento<br />para a Estação Fazenda</h2>
    <LeadForm
      formId="lead-form"
      class="bio-form-card"
      prefix="bio"
      project={config.project_slug}
      submitUrl={config.forms['lead-form'].webhooks[0]}
      redirectUrl={config.forms['lead-form'].redirect_on_success}
      submitText="Solicitar orçamento"
      honeypot
      successTitle="Solicitação recebida!"
      successText="Em breve nossa equipe entrará em contato para apresentar a Estação Fazenda e enviar um orçamento personalizado."
      fields={[
        { name: 'nome',     type: 'text',  label: 'Nome completo', placeholder: 'Seu nome', required: true, full: true },
        { type: 'row', fields: [
          { name: 'telefone', type: 'tel',   label: 'WhatsApp',  placeholder: '(00) 00000-0000', required: true },
          { name: 'email',    type: 'email', label: 'E-mail',    placeholder: 'seu@email.com',   required: true }
        ]},
        { name: 'Tipo de evento', type: 'select', label: 'Tipo de evento', required: true, full: true, options: [
          { value: '',                                label: 'Tipo de evento',                 disabled: true, selected: true },
          { value: 'Casamento',                       label: 'Casamento'                       },
          { value: 'Bodas',                           label: 'Bodas'                           },
          { value: 'Aniversário',                     label: 'Aniversário'                     },
          { value: 'Aniversário debutante',           label: 'Aniversário debutante'           },
          { value: 'Confraternização social',         label: 'Confraternização social'         },
          { value: 'Formatura',                       label: 'Formatura'                       },
          { value: 'Corporativo',                     label: 'Corporativo'                     },
          { value: 'Outros',                          label: 'Outros'                          },
        ]},
        { type: 'row', fields: [
          { name: 'data',       type: 'text',   label: 'Data do evento',   placeholder: 'dd/mm/aaaa', required: true },
          { name: 'Convidados', type: 'number', label: 'Nº de convidados', placeholder: 'Ex: 150',    required: true }
        ]},
        { name: 'Mensagem', type: 'textarea', label: 'Mensagem', placeholder: 'Informações adicionais (não obrigatório)', required: false, full: true }
      ]}
    />
  </section>

  <!-- FOOTER -->
  <footer class="bio-footer">
    <img src={LOGO} alt="Grupo Conti Eventos" class="bio-footer__logo" width="280" height="93" />
    <div class="bio-footer__bottom">
      <p class="bio-footer__copy">&copy; 2026 Grupo Conti Eventos — Todos os direitos reservados.</p>
      <a href="https://dmove.com.br/" target="_blank" rel="noopener noreferrer" class="bio-footer__dmove">
        Desenvolvido por
        <img src={DMOVE} alt="Dmove" class="bio-footer__dmove-logo" width="80" height="18" />
      </a>
    </div>
  </footer>

</Base>

<script>
  import '../scripts/bio.js';
</script>
