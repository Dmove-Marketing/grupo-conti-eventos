  <section class="contact" id="contato">
    <div class="contact-info" data-reveal>
      <span class="eyebrow eyebrow--gold">Próximo passo</span>
      <h2>Vamos começar <br class="mobile-br" />seu próximo <br />evento corporativo?</h2>
      <p>Preencha o formulário e receba orçamento personalizado para sua empresa.</p>
    </div>
    <div class="contact-form-wrap">
      <form
        id="contactForm"
        data-form-id="lead-form"
        data-project={config.project_slug}
        data-submit-url={config.forms['lead-form'].webhooks[0]}
        data-redirect={config.forms['lead-form'].redirect_on_success}
        data-grid-id="contactForm"
        data-success-id="formConfirm"
        novalidate
      >
        <div class="hp-field" style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;" aria-hidden="true">
          <label for="contactForm_website">Deixe este campo em branco</label>
          <input type="text" id="contactForm_website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="form-grid">
          <div class="field field--full">
            <label for="nome">Nome</label>
            <input id="nome" name="nome" type="text" placeholder="Seu nome completo" required>
          </div>
          <div class="field">
            <label for="telefone">Telefone</label>
            <input id="telefone" name="telefone" type="tel" placeholder="(11) 9 0000-0000" required>
          </div>
          <div class="field">
            <label for="email">E-mail</label>
            <input id="email" name="email" type="email" placeholder="seu@email.com" required>
          </div>
          <div class="field field--full">
            <label for="empresa">Empresa</label>
            <input id="empresa" name="empresa" type="text" placeholder="Nome da sua empresa" required>
          </div>
          <div class="field">
            <label for="data">Data do evento</label>
            <input id="data" name="data" type="date" required>
          </div>
          <div class="field">
            <label for="convidados">Nº de convidados</label>
            <input id="convidados" name="convidados" type="number" min="1" placeholder="Nº de pessoas" required>
          </div>
          <div class="field field--full">
            <label for="evento">Tipo de evento</label>
            <select id="evento" name="evento" required>
              <option value="" disabled selected>Selecione o tipo de evento</option>
              <option value="Confraternização corporativo">Confraternização corporativo</option>
              <option value="Corporativo">Corporativo</option>
              <option value="Feiras e Exposições">Feiras e Exposições</option>
              <option value="Masterclass e Palestras">Masterclass e Palestras</option>
              <option value="Mentorias e Treinamentos">Mentorias e Treinamentos</option>
              <option value="Offsite corporativo">Offsite corporativo</option>
              <option value="Reuniões de Networking">Reuniões de Networking</option>
              <option value="Workshops, Conferências e Seminários">Workshops, Conferências e Seminários</option>
              <option value="Outros">Outros</option>
            </select>
          </div>
        </div>

        <button type="button" class="btn btn-primary btn-block form-submit" style="margin-top:22px">
          <span class="btn-text">Solicitar Orçamento</span>
          <span class="btn-loading" style="display:none; align-items: center; justify-content: center; gap: 8px;">
            <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation: spin 1s linear infinite;">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
            </svg>
            Enviando...
          </span>
        </button>
        <p class="form-note">Seus dados são usados apenas para retorno de contato e orçamento.</p>
        <div class="form-error" style="color: #ef4444; font-size: 0.875rem; margin-top: 4px; display: none;"></div>
      </form>
      <div class="form-confirm" id="formConfirm">
        <h3>Recebemos sua solicitação!</h3>
        <p>Em breve nossa equipe entrará em contato para dar continuidade ao planejamento do seu evento corporativo.</p>
      </div>
    </div>
  </section>

