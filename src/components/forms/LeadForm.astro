---
interface FieldOption {
  value: string;
  label: string;
  disabled?: boolean;
  selected?: boolean;
}

interface Field {
  name: string;
  type: 'text' | 'email' | 'tel' | 'number' | 'select' | 'textarea' | 'hidden' | 'radio';
  label?: string;
  placeholder?: string;
  required?: boolean;
  full?: boolean;
  id?: string;
  autocomplete?: string;
  errorText?: string;
  errorId?: string;
  maxlength?: number;
  minlength?: number;
  pattern?: string;
  min?: string;
  max?: string;
  readonly?: boolean;
  rows?: number;
  options?: FieldOption[];
  value?: string;
}

interface FieldRow {
  type: 'row';
  fields: Field[];
}

type AnyField = Field | FieldRow;

interface Props {
  formId: string;
  project: string;
  submitUrl?: string;
  redirectUrl?: string;
  submitText?: string;
  fields?: AnyField[];
  class?: string;
  prefix?: string;
  gridId?: string;
  submitId?: string;
  honeypot?: boolean;
  successTitle?: string;
  successText?: string;
}

const {
  formId,
  project,
  submitUrl,
  redirectUrl,
  submitText = 'Enviar',
  fields = [
    { name: 'nome',     type: 'text',  placeholder: 'Nome completo', required: true },
    { name: 'telefone', type: 'text',  placeholder: 'WhatsApp',      required: true },
    { name: 'email',    type: 'email', placeholder: 'E-mail',        required: true },
  ] as AnyField[],
  class: className,
  prefix = '',
  gridId,
  submitId,
  honeypot = true,
  successTitle = 'Solicitação recebida',
  successText = 'Recebemos seu pedido.<br>Em breve entraremos em contato pelo WhatsApp ou e-mail.',
} = Astro.props;

const formElemId = `form-${formId}`;
const theGridId = gridId || (prefix ? `${prefix}FormGrid` : `${formId}Grid`);
const theSubmitId = submitId || (prefix ? `${prefix}SubmitBtn` : `${formId}SubmitBtn`);
const theSuccessId = prefix ? `${prefix}Success` : `${formId}Success`;
const theMsgId = prefix ? `${prefix}FormMsg` : `${formId}FormMsg`;

const p = prefix ? prefix : null;
const cxGrid    = p ? `${p}-form-grid`    : 'lead-form-grid';
const cxRow     = p ? `${p}-form-row`     : 'form-row';
const cxLabel   = p ? `${p}-label`        : 'form-label';
const cxInput   = p ? `${p}-input`        : 'form-input';
const cxSelect  = p ? `${p}-select`       : 'form-select';
const cxArea    = p ? `${p}-textarea`     : 'form-textarea';
const cxError   = p ? `${p}-field-error`  : 'field-error';
const cxMsg     = p ? `${p}-form-msg`     : 'form-error';
const cxFooter  = p ? `${p}-form-footer`  : 'form-footer';
const cxSuccess      = p ? `${p}-success-state`  : 'form-success-state';
const cxRadioGroup   = p ? `${p}-radio-group`    : 'form-radio-group';
const cxRadioLabel   = p ? `${p}-radio-label`    : 'form-radio-label';
const cxSIcon   = p ? `${p}-success-icon`   : 'form-success-icon';
const cxSTitle  = p ? `${p}-success-title`  : 'form-success-title';
const cxSText   = p ? `${p}-success-text`   : 'form-success-text';
const cxSubmit  = p ? `${p}-submit form-submit` : 'btn btn-primary form-submit';
const groupCls  = (full?: boolean) => {
  const base = p ? `${p}-form-group` : 'form-group';
  return full ? `${base} full` : base;
};
---

<form
  id={formElemId}
  name={formId}
  class:list={[!prefix && 'lead-form', className]}
  data-form-id={formId}
  data-project={project}
  data-submit-url={submitUrl}
  data-redirect={redirectUrl}
  data-grid-id={theGridId}
  data-success-id={theSuccessId}
  novalidate
>
  {honeypot && (
    <div class="hp-field" aria-hidden="true">
      <label for={`${formId}_website`}>Deixe este campo em branco</label>
      <input type="text" id={`${formId}_website`} name="website" tabindex="-1" autocomplete="off" />
    </div>
  )}

  <div class={cxGrid} id={theGridId}>
    {fields.map((fieldOrRow) => {
      if (fieldOrRow.type === 'row') {
        const row = fieldOrRow as FieldRow;
        return (
          <div class={cxRow}>
            {row.fields.map((f) => (
              <div class={groupCls(f.full)}>
                {f.label && <label class={cxLabel} for={f.id ?? f.name}>{f.label}</label>}
                {f.type === 'select' ? (
                  <select class={cxSelect} name={f.name} id={f.id ?? f.name} required={f.required}>
                    {f.options?.map((opt) => (
                      <option value={opt.value} disabled={opt.disabled} selected={opt.selected}>{opt.label}</option>
                    ))}
                  </select>
                ) : f.type === 'textarea' ? (
                  <textarea class={cxArea} name={f.name} id={f.id ?? f.name} rows={f.rows ?? 4} placeholder={f.placeholder} required={f.required}></textarea>
                ) : f.type === 'hidden' ? (
                  <input type="hidden" name={f.name} id={f.id ?? f.name} value={f.value} />
                ) : f.type === 'radio' ? (
                  <div class={cxRadioGroup}>
                    {f.options?.map((opt) => (
                      <label class={cxRadioLabel}>
                        <input type="radio" name={f.name} value={opt.value} required={f.required} />
                        <span>{opt.label}</span>
                      </label>
                    ))}
                  </div>
                ) : (
                  <input
                    class={cxInput}
                    type={f.type}
                    name={f.name}
                    id={f.id ?? f.name}
                    placeholder={f.placeholder}
                    required={f.required}
                    autocomplete={f.autocomplete}
                    maxlength={f.maxlength}
                    minlength={f.minlength}
                    pattern={f.pattern}
                    min={f.min}
                    max={f.max}
                    readonly={f.readonly}
                  />
                )}
                {f.errorText && <span class={cxError} id={f.errorId}>{f.errorText}</span>}
              </div>
            ))}
          </div>
        );
      }

      const f = fieldOrRow as Field;

      if (f.type === 'hidden') {
        return <input type="hidden" name={f.name} id={f.id ?? f.name} value={f.value} />;
      }

      return (
        <div class={groupCls(f.full)}>
          {f.label && <label class={cxLabel} for={f.id ?? f.name}>{f.label}</label>}
          {f.type === 'select' ? (
            <select class={cxSelect} name={f.name} id={f.id ?? f.name} required={f.required}>
              {f.options?.map((opt) => (
                <option value={opt.value} disabled={opt.disabled} selected={opt.selected}>{opt.label}</option>
              ))}
            </select>
          ) : f.type === 'textarea' ? (
            <textarea class={cxArea} name={f.name} id={f.id ?? f.name} rows={f.rows ?? 4} placeholder={f.placeholder} required={f.required}></textarea>
          ) : f.type === 'radio' ? (
            <div class={cxRadioGroup}>
              {f.options?.map((opt) => (
                <label class={cxRadioLabel}>
                  <input type="radio" name={f.name} value={opt.value} required={f.required} />
                  <span>{opt.label}</span>
                </label>
              ))}
            </div>
          ) : (
            <input
              class={cxInput}
              type={f.type}
              name={f.name}
              id={f.id ?? f.name}
              placeholder={f.placeholder}
              required={f.required}
              autocomplete={f.autocomplete}
              maxlength={f.maxlength}
              minlength={f.minlength}
              pattern={f.pattern}
              min={f.min}
              max={f.max}
              readonly={f.readonly}
            />
          )}
          {f.errorText && <span class={cxError} id={f.errorId}>{f.errorText}</span>}
        </div>
      );
    })}

    <div class={groupCls(true)}>
      <button type="button" class={cxSubmit} id={theSubmitId}>
        <span class="btn-text">{submitText}</span>
        <span class="btn-loading" style="display:none;">
          <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
          </svg>
          Enviando...
        </span>
      </button>
    </div>

    <div class={cxMsg} id={theMsgId}></div>
    <p class={cxFooter}>Ao enviar, você concorda com nossa política de privacidade.</p>
  </div>

  <div class={cxSuccess} id={theSuccessId}>
    <div class={cxSIcon}>
      <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
    </div>
    <h3 class={cxSTitle}>{successTitle}</h3>
    <p class={cxSText} set:html={successText}></p>
  </div>
</form>

<script>
  import { initForms } from '../../scripts/forms.ts';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initForms);
  } else {
    initForms();
  }
</script>

<style>
  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
    width: 100%;
    max-width: 440px;
  }

  .lead-form-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md, 1rem);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary, #111);
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--glass-border, #d1d5db);
    border-radius: 6px;
    font-size: 0.95rem;
    background: var(--bg-card, #fff);
    color: var(--text-primary, #111);
    transition: border-color 0.15s;
    font-family: inherit;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-primary, #2563eb);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-muted, #999);
  }

  .field-error {
    font-size: 0.78rem;
    color: #ef4444;
    display: none;
  }

  .field-error.visible {
    display: block;
  }

  .form-submit {
    width: 100%;
    margin-top: var(--space-sm, 0.5rem);
    font-size: 1.05rem;
    padding: 14px var(--space-xl, 2rem);
    cursor: pointer;
  }

  .form-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .btn-loading {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .form-error {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 4px;
    display: none;
  }

  .form-success-state {
    display: none;
    text-align: center;
    padding: var(--space-xl, 2rem);
  }

  .form-success-state.active {
    display: block;
  }

  .form-success-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md, 1rem);
    background: var(--color-primary, #2563eb);
    border-radius: 50%;
    color: white;
  }

  .form-success-icon svg {
    width: 28px;
    height: 28px;
    stroke: white;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .form-success-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary, #111);
    margin-bottom: 4px;
  }

  .form-success-text {
    color: var(--text-secondary, #666);
    font-size: 0.9rem;
  }

  .form-footer {
    font-size: 0.75rem;
    color: var(--text-secondary, #888);
    text-align: center;
  }

  .form-radio-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm, 0.5rem);
  }

  .form-radio-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--text-primary, #111);
  }

  .form-radio-label input[type="radio"] {
    accent-color: var(--color-primary, #2563eb);
    width: 16px;
    height: 16px;
    cursor: pointer;
  }
</style>
